PORT=4173
NODE_ENV=development
ADMIN_EMAIL=
ADMIN_PASSWORD=
TOKEN_SECRET=replace-with-a-long-random-secret
PUBLIC_SITE_URL=http://localhost:4173
PRICE_SYNC_INTERVAL_MINUTES=360
AUTO_PRICE_SYNC=false
ALLOW_HTML_FETCH=false
TERMS_ACKNOWLEDGED_DOMAINS=

AUTO_IMAGE_SYNC=true
IMAGE_SYNC_CONCURRENCY=4
IMAGE_SYNC_TIMEOUT_MS=12000

# E-posta doğrulama (Gmail için uygulama şifresi kullanın)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=ArduFiyat <no-reply@example.com>

# Google Cloud Console OAuth 2.0 Web Client ID
GOOGLE_CLIENT_ID=

# Discord topluluğu (Pro erişimi admin panelinden manuel verilir)
DISCORD_INVITE_URL=https://discord.gg/gT96uAfuA
