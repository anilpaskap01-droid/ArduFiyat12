PORT=4173
NODE_ENV=development
# Render persistent disk örneği: /var/data
ARDUFIYAT_DATA_DIR=
DATABASE_URL=postgresql://postgres.PROJECT_REF:[YOUR_PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
TOKEN_SECRET=generate-a-long-random-secret
PUBLIC_SITE_URL=http://localhost:4173
PRICE_SYNC_INTERVAL_MINUTES=360
AUTO_PRICE_SYNC=false
ALLOW_HTML_FETCH=false
TERMS_ACKNOWLEDGED_DOMAINS=

AUTO_IMAGE_SYNC=true
IMAGE_SYNC_CONCURRENCY=4
IMAGE_SYNC_TIMEOUT_MS=12000

# E-posta doğrulama (Gmail için uygulama şifresi kullanın)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=ArduFiyat <your-email@example.com>

# Google Cloud Console OAuth 2.0 Web Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Gemini URL Context ile teklif fiyat/stok doğrulama
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash
GEMINI_PRICE_BATCH_SIZE=8
GEMINI_PRICE_BATCH_DELAY_MS=350

# Discord topluluğu (Pro erişimi admin panelinden manuel verilir)
DISCORD_INVITE_URL=https://discord.gg/your-invite
